# Resolve react_native_pods.rb with node to allow for hoisting
require Pod::Executable.execute_command('node', ['-p',
  'require.resolve(
    "react-native/scripts/react_native_pods.rb",
    {paths: [process.argv[1]]},
  )', __dir__]).strip

platform :ios, min_ios_version_supported
prepare_react_native_project!

linkage = ENV['USE_FRAMEWORKS']
if linkage != nil
  Pod::UI.puts "Configuring Pod with #{linkage}ally linked Frameworks".green
  use_frameworks! :linkage => linkage.to_sym
end

target 'InappstorySdkExample' do
  config = use_native_modules!
  #pod 'SVGKit'
  #pod 'CocoaLumberjack'
  use_react_native!(
    :path => config[:reactNativePath],
    # An absolute path to your application root.
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

  target 'InappstorySdkExampleTests' do
    inherit! :complete
    # Pods for testing
  end

  post_install do |installer|
    # https://github.com/facebook/react-native/blob/main/packages/react-native/scripts/react_native_pods.rb#L197-L202
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
      #:ccache_enabled => true
    )
    # fmt 11.0.2 re-enables consteval on Xcode 16+/iOS 26 SDK Apple clang, breaking
    # format.cc & Folly. fmt already special-cases broken Apple clang but caps it at
    # __apple_build_version__ < 14000029L; drop the cap so all Apple clang uses the
    # constexpr fallback (FMT_USE_CONSTEVAL 0). base.h redefines the macro
    # unconditionally, so a -D define can't win — patch the header instead.
    fmt_base = File.join(__dir__, 'Pods/fmt/include/fmt/base.h')
    if File.exist?(fmt_base)
      text = File.read(fmt_base)
      patched = text.sub(
        "#elif defined(__apple_build_version__) && __apple_build_version__ < 14000029L",
        "#elif defined(__apple_build_version__)"
      )
      File.write(fmt_base, patched) if patched != text
    end
    #installer.pods_project.targets.each do |target|
    #  target.build_configurations.each do |config|
    #      config.build_settings['ONLY_ACTIVE_ARCH'] = 'YES'
    #      config.build_settings['BUILD_LIBRARY_FOR_DISTRIBUTION'] = 'YES'
    #  end
    #end
  end
end